{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a student profile in the Ponte platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "age": { "type": "integer" },
        "school": { "type": "string" },
        "grade": { "type": "string" },
        "subjectsExpert": { "type": "array", "items": { "type": "string" } },
        "subjectsLearning": { "type": "array", "items": { "type": "string" } },
        "knowledgeLevels": { 
          "type": "object", 
          "description": "Map of subject to level (1-5)"
        },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "reputation": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "streak": { "type": "integer" },
        "hoursStudied": { "type": "number" },
        "peopleHelpedCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "HelpRequest": {
      "title": "Help Request Note",
      "description": "A request for help in a specific subject.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "minLevel": { "type": "integer" },
        "availableTime": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "active", "closed"] },
        "chatEnabled": { "type": "boolean" },
        "validatorQuizId": { "type": "string", "description": "ID of the AI generated quiz" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "subject", "minLevel", "status"]
    },
    "Session": {
      "title": "Study Session",
      "description": "An active collaboration session between students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requestId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ongoing", "completed"] },
        "notes": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a session chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/helpRequests/{requestId}": {
      "schema": "HelpRequest",
      "description": "Active help requests"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Active and past sessions"
    },
    "/sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages in a session"
    }
  }
}
